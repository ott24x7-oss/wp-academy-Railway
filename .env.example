# ─── Supabase ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Application ──────────────────────────
NEXT_PUBLIC_BASE_URL=https://academy.watshop.in
NODE_ENV=production
PORT=3000

# ─── Payment: UPI ──────────────────────────
UPI_ID=yourname@paytm

# ─── Payment: Binance / Crypto ──────────────────────────
BINANCE_USDT_ADDRESS=TXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BTC_ADDRESS=bc1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LTC_ADDRESS=ltc1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Payment Verification: Gmail IMAP ──────────────────────────
# Used to auto-detect payment emails (Paytm, Binance, etc.)
PAYMENT_IMAP_EMAIL=payments@yourdomain.com
PAYMENT_IMAP_PASSWORD=your-gmail-app-password

# ─── Email: PHPMailer + SMTP Fallback ──────────────────────────
SMTP_EMAIL=hello@yourdomain.com
SMTP_PASSWORD=gmail-app-password
SMTP_FROM_NAME=WatShop Academy
EMAIL_ENABLED=1
# Optional: override default PHP mailer endpoint
PHP_MAILER_URL=https://yourdomain.com/mailer/send.php

# ─── AI ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Social Posting (Ayrshare) ──────────────────────────
AYRSHARE_API_KEY=your-ayrshare-key
AYRSHARE_DOMAIN=your-ayrshare-profile-key

# ─── Meta Ads OAuth ──────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://academy.watshop.in/api/oauth/meta/callback

# ─── Google Ads OAuth ──────────────────────────
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-google-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_REDIRECT_URI=https://academy.watshop.in/api/oauth/google/callback

# ─── LinkedIn OAuth ──────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-id
LINKEDIN_CLIENT_SECRET=your-linkedin-secret

# ─── TikTok OAuth ──────────────────────────
TIKTOK_CLIENT_KEY=your-tiktok-key
TIKTOK_CLIENT_SECRET=your-tiktok-secret

# ─── YouTube ──────────────────────────
YOUTUBE_DATA_API_KEY=your-youtube-api-key

# ─── Encryption (32-byte hex) ──────────────────────────
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
